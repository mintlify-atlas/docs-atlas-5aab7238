  "keyFeatures": [
    "Divide large geographic areas of interest into small, mappable tasks",
    "OSM OAuth2 authentication for all contributors",
    "Role-based access: mapper, validator, project manager, organisation admin",
    "Real-time task locking to prevent duplicate mapping",
    "Integration with iD, Rapid, JOSM, and Potlatch2 editors",
    "ohsome Now Stats integration for live OSM contribution metrics",
    "Team and organisation management with partner pages",
    "Automated task unlocking via cron jobs",
    "Multilingual support (26+ languages)",
    "Docker-based deployment with AWS CloudFormation support",
    "FastAPI backend with async PostgreSQL (PostGIS) and ReactJS frontend",
    "Sandbox/practice project mode for new mappers",
    "OSM data export per project via EXPORT_TOOL integration"
  ],
  "publicApiSurface": [
